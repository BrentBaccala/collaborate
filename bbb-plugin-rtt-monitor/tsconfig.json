{
  "compilerOptions": {
    "outDir": "./dist-tsc/",
    "noImplicitAny": true,
    "skipLibCheck": true,
    "module": "es6",
    "target": "es5",
    "jsx": "react",
    "allowJs": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "lib": ["dom", "es2017"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
