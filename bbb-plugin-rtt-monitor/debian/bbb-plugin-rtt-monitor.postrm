#!/bin/bash
set -e

BBB_WEB_PROPS=/etc/bigbluebutton/bbb-web.properties

case "$1" in
    remove|purge)
        if [ -f "$BBB_WEB_PROPS" ]; then
            CURRENT=$(grep -oP '(?<=^pluginManifests=).*' "$BBB_WEB_PROPS" 2>/dev/null || echo "")

            if echo "$CURRENT" | grep -q "rtt-monitor/manifest.json"; then
                NEW=$(echo "$CURRENT" | sed 's/,\?{"url":"[^"]*rtt-monitor\/manifest.json"}//g' | sed 's/\[,/[/')

                if [ "$NEW" = "[]" ] || [ -z "$NEW" ]; then
                    sed -i '/^pluginManifests=/d' "$BBB_WEB_PROPS"
                    echo "pluginManifests=" >> "$BBB_WEB_PROPS"
                else
                    sed -i "s|^pluginManifests=.*|pluginManifests=$NEW|" "$BBB_WEB_PROPS"
                fi
                echo "bbb-plugin-rtt-monitor: removed manifest from bbb-web.properties"
            fi
        fi
        ;;
esac

#DEBHELPER#
