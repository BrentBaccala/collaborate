# Accept /proxy (no trailing slash) as well as /proxy/. The location
# below is a prefix match that a URI of exactly "/proxy" does not
# satisfy, so without this it falls through to BBB's catch-all and the
# WebSocket upgrade fails (code 1006). An internal rewrite (not an HTTP
# redirect) is used because a WebSocket handshake does not follow 3xx.
location = /proxy {
        rewrite ^ /proxy/ last;
}

location /proxy/ {
        proxy_pass http://localhost:6101/;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_read_timeout 6h;
        proxy_send_timeout 6h;
        client_body_timeout 6h;
        send_timeout 6h;
}
