#!/usr/bin/python3
#
# Checks every 60 seconds to see if nobody is logged in, 'swapoff' is
# not running, and no Big Blue Button meetings are running.  If so,
# hibernate ourself and, optionally, stop a list of other AWS EC2
# instances.  Waits HIBERNATE_GRACE_SECONDS (default 300) after a boot or a
# resume before it is willing to hibernate, so a freshly-woken server isn't
# put right back to sleep before users have a chance to (re)connect.
#
# Credentials come from the standard boto3 chain.  Preferred setup is a
# scoped static key in /etc/default/bbb-aws-hibernate (see README.md and
# create-hibernate-controller), readable only by this service, granting
# ec2:StopInstances on this instance.  An instance profile also works but
# serves its role credentials to every local user via IMDS -- see README.md.

import os
import time
import boto3
import botocore
import psutil
import datetime
import requests
import re

import bigbluebutton

# Special AWS REST API calls to a link-local address to get our instance data.

aws_region = requests.get('http://169.254.169.254/latest/meta-data/placement/region').text
my_instance_id = requests.get('http://169.254.169.254/latest/meta-data/instance-id').text

def ec2():
    if not hasattr(ec2, 'retval'):
        session = boto3.Session(region_name = aws_region)
        ec2.retval = session.client('ec2')
    return ec2.retval

def is_server_idle():
    try:
        # machinectl shell allocates a PTY for VNC desktops, so both VNC and SSH users have user.terminal set.
        # The difference is that SSH sessions have a remote host, while VNC/machinectl sessions have host=''.
        if len([user for user in psutil.users() if user.host]) > 0:
            return False
        # AWS tech support advised against attempting to hibernate while the
        # swapoff process from the previous hibernation is still running
        if any(proc.name() == 'swapoff' for proc in psutil.process_iter()):
            return False
        xml = bigbluebutton.getMeetings()
        return len(xml.xpath('.//meeting')) == 0
    except:
        return False

# AWS-CLI --filters shorthand: space-separated specs, each "Name=KEY,Values=V1[,V2,...]".
def parse_filter_shorthand(s):
    filters = []
    for spec in s.split():
        m = re.match(r'^Name=([^,]+),Values=(.+)$', spec)
        if not m:
            raise ValueError(f"bad filter spec: {spec!r} (expected Name=KEY,Values=V1[,V2,...])")
        filters.append({'Name': m.group(1), 'Values': m.group(2).split(',')})
    return filters

# "TAG1=VALUE1, TAG2=VALUE2" -> list of EC2 tag-filter dicts (AND-of-equalities).
def parse_tag_shorthand(s):
    filters = []
    for pair in re.split(r'\s*,\s*', s.strip()):
        if not pair:
            continue
        k, _, v = pair.partition('=')
        filters.append({'Name': f'tag:{k.strip()}', 'Values': [v.strip()]})
    return filters

# Union of ADDITIONAL_STOP_INSTANCES (explicit IDs), ADDITIONAL_STOP_TAGS, and
# ADDITIONAL_STOP_FILTERS, minus our own instance ID. Tag/filter resolution is
# restricted to running instances; the explicit list is taken as-is.
def additional_stop_instance_ids():
    ids = set()

    if os.environ.get('ADDITIONAL_STOP_INSTANCES'):
        ids.update(s for s in (s.strip() for s in re.split(r'\s*,\s*', os.environ['ADDITIONAL_STOP_INSTANCES'])) if s)

    filters = []
    if os.environ.get('ADDITIONAL_STOP_TAGS'):
        filters.extend(parse_tag_shorthand(os.environ['ADDITIONAL_STOP_TAGS']))
    if os.environ.get('ADDITIONAL_STOP_FILTERS'):
        filters.extend(parse_filter_shorthand(os.environ['ADDITIONAL_STOP_FILTERS']))

    if filters:
        filters.append({'Name': 'instance-state-name', 'Values': ['running']})
        try:
            for reservation in ec2().describe_instances(Filters=filters)['Reservations']:
                for instance in reservation['Instances']:
                    ids.add(instance['InstanceId'])
        except botocore.exceptions.ClientError as ex:
            print("Failed to resolve ADDITIONAL_STOP_TAGS/FILTERS:", ex)

    ids.discard(my_instance_id)
    return sorted(ids)

def main():
    # Don't hibernate within `grace` seconds of a boot or a resume-from-
    # hibernate, so a freshly-woken server gives users time to (re)connect
    # before it can put itself back to sleep.  Without this the loop would
    # hibernate on its first idle check -- moments after the service starts,
    # or right after a wake before anyone has joined a meeting.
    #
    # A process-start timestamp won't do: on resume this very process is
    # restored from the hibernation image (not restarted), so its start time
    # is stale.  Instead detect the resume itself -- CLOCK_MONOTONIC pauses
    # while suspended but CLOCK_BOOTTIME keeps counting, so a gap between the
    # two across one sleep means we were suspended and have just resumed.
    grace = int(os.environ.get('HIBERNATE_GRACE_SECONDS', '300'))
    awake_since = time.monotonic()
    prev_mono = awake_since
    prev_boot = time.clock_gettime(time.CLOCK_BOOTTIME)

    while True:
        time.sleep(60)

        now_mono = time.monotonic()
        now_boot = time.clock_gettime(time.CLOCK_BOOTTIME)
        if (now_boot - prev_boot) - (now_mono - prev_mono) > 5:
            awake_since = now_mono          # resumed from suspend; restart the grace window
        prev_mono, prev_boot = now_mono, now_boot

        if now_mono - awake_since < grace:
            continue                        # still within the post-boot/resume grace window

        if is_server_idle():
            print("Hibernating instances at", datetime.datetime.now())
            instance_ids = additional_stop_instance_ids()
            if instance_ids:
                print("Stopping", instance_ids, "at", datetime.datetime.now())
                # First try to stop all additional instances.  If that doesn't
                # work, try to stop them individually, logging any errors.
                try:
                    ec2().stop_instances(InstanceIds = instance_ids)
                except botocore.exceptions.ClientError:
                    for instance in instance_ids:
                        try:
                            ec2().stop_instances(InstanceIds = [instance])
                        except botocore.exceptions.ClientError as ex:
                            print(ex)
            print("Hibernating", my_instance_id, "at", datetime.datetime.now())
            try:
                ec2().stop_instances(InstanceIds=[my_instance_id], Hibernate=True)
            except botocore.exceptions.ClientError as ex:
                print("Failed to self-hibernate:", ex)

if __name__ == "__main__":
    main()
